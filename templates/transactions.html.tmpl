<div class="mb-6 flex items-end justify-between gap-4 border-b border-slate-200 pb-4">
    <div>
        <p class="text-sm font-medium text-slate-500">Total</p>
        <h3 class="text-2xl font-bold tracking-tight text-slate-900">{{ .Sum }} NOK</h3>
    </div>
</div>

<div class="space-y-4">
    {{ range .Transactions }}
    <div
        id="transaction-{{ .ID }}"
        class="group flex items-start justify-between gap-4 rounded-2xl border border-slate-200 p-4 shadow-sm transition hover:shadow-md bg-blue-50"
    >
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
                <p class="text-lg font-semibold">
                    {{ .Amount }} NOK
                </p>
            </div>

            <p class="mt-2 text-sm text-slate-700">
                {{ .Description }}
            </p>

            <!-- metadata row -->
            <div class="mt-3 flex items-center justify-between gap-4 text-xs">
                <!-- left side: tags -->
                <div class="flex flex-wrap items-center gap-2">
                    <!-- category -->
                    <span class="rounded-md bg-slate-100 px-2 py-1 text-slate-600">
                        {{ .Category }}
                    </span>

                    <!-- shared/private -->
                    <span class="rounded-md px-2 py-1 font-medium {{ if eq .Shared "on" }}bg-blue-100 text-blue-700{{ else }}bg-slate-200 text-slate-600{{ end }}">
                        {{ if eq .Shared "on" }}Felles{{ else }}Privat{{ end }}
                    </span>
                </div>

                <!-- right side: meta -->
                <div class="flex items-center gap-3 text-slate-400">
                    <!-- date -->
                    <span>
                        {{ .Date }}
                    </span>

                    <!-- user -->
                    <span>
                        {{ .Login }}
                    </span>
                </div>
            </div>
        </div>

        <button
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-rose-600 focus:outline-none focus:ring-4 focus:ring-slate-200"
            hx-delete="/api/transaction/{{ .ID }}"
            hx-target="#transaction-{{ .ID }}"
            hx-swap="outerHTML"
            hx-confirm="er du sikker på at du vil slette denne transaksjonen?"
            aria-label="slett transaksjon"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>
    {{ end }}
</div>
