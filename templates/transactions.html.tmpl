<div class="mb-6 flex items-end justify-between gap-4 border-b border-slate-200 pb-4">
    <div>
        <p class="text-sm font-medium text-slate-500">Total</p>
        <h3 class="text-2xl font-bold tracking-tight text-slate-900">{{ .Sum }} NOK</h3>
    </div>
</div>

<div class="space-y-4">
    {{ range .Transactions }}
    <div
        id="transaction-{{ .ID }}"
        class="group flex items-start justify-between gap-4 rounded-2xl border border-slate-200 p-4 shadow-sm transition hover:shadow-md {{ if lt .Amount 0 }}bg-rose-50{{ else }}bg-emerald-50{{ end }}"
    >
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
                <p class="text-lg font-semibold {{ if lt .Amount 0 }}text-rose-700{{ else }}text-emerald-700{{ end }}">
                    {{ if gt .Amount 0 }}+{{ end }}{{ .Amount }} NOK
                </p>
                <span class="rounded-full px-2.5 py-1 text-xs font-medium {{ if lt .Amount 0 }}bg-rose-100 text-rose-700{{ else }}bg-emerald-100 text-emerald-700{{ end }}">
                    {{ if lt .Amount 0 }}Utgift{{ else }}Inntekt{{ end }}
                </span>
            </div>

            <p class="mt-2 text-sm text-slate-600">{{ .Description }}</p>
            <p class="mt-3 text-xs text-slate-400">{{ .UserEmail }}</p>
        </div>

        <button
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-rose-600 focus:outline-none focus:ring-4 focus:ring-slate-200"
            hx-delete="/api/transaction/{{ .ID }}"
            hx-target="#transaction-{{ .ID }}"
            hx-swap="outerHTML"
            hx-confirm="Er du sikker på at du vil slette denne transaksjonen?"
            aria-label="Slett transaksjon"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>
    {{ end }}
</div>
